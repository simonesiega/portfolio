{
  "name": "portfolio",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.14",
  "scripts": {
    "dev": "next dev",
    "start": "next start",
    "build": "next build",
    "build:local": "SITE_URL=https://simonesiega.com bun run build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "prettier": "prettier --check .",
    "format:check": "bun run prettier",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:e2e:server": "bun run build:local && SITE_URL=https://simonesiega.com next start --port 3100",
    "test:e2e": "playwright test",
    "check": "bun run prettier && bun run lint && bun run typecheck && bun run build:local",
    "ci": "bun run check"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md,yml,yaml}": "prettier --write"
  },
  "dependencies": {
    "next": "16.2.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-icons": "^5.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.0"
  }
}
