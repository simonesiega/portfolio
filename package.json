{
  "name": "portfolio",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.14",
  "scripts": {
    "dev": "next dev",
    "start": "node .next/standalone/server.js",
    "build": "next build",
    "build:local": "SITE_URL=https://simonesiega.com bun run build",
    "build:standalone:local": "bun run build:local && bun -e \"const fs = require('node:fs'); fs.cpSync('public', '.next/standalone/public', {recursive: true, force: true}); fs.cpSync('.next/static', '.next/standalone/.next/static', {recursive: true, force: true});\"",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "prettier": "prettier --check .",
    "format:check": "bun run prettier",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:e2e:server": "bun run build:standalone:local && SITE_URL=https://simonesiega.com HOSTNAME=127.0.0.1 PORT=3100 node .next/standalone/server.js",
    "test:e2e": "playwright test",
    "check": "bun run format:check && bun run lint && bun run typecheck && bun run build:local",
    "ci": "bun run check"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md,yml,yaml}": "prettier --write"
  },
  "overrides": {
    "@babel/core": "7.29.7",
    "flatted": "3.4.2",
    "js-yaml": "5.2.0",
    "picomatch": "4.0.4",
    "postcss": "8.5.16",
    "vite": "8.1.2"
  },
  "dependencies": {
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@next/mdx": "16.2.9",
    "next": "16.2.9",
    "react": "19.2.3",
    "react-dom": "19.2.7",
    "react-icons": "^5.7.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@mdx-js/rollup": "^3.1.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/node": "^20.19.43",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.9",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.9.4",
    "prettier-plugin-tailwindcss": "^0.7.4",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9"
  }
}
