# Umami analytics configuration. See https://umami.is/docs/nextjs for more details.
NEXT_PUBLIC_UMAMI_ENABLED=false
NEXT_PUBLIC_UMAMI_SCRIPT_SRC=https://cloud.umami.is/script.js
NEXT_PUBLIC_UMAMI_WEBSITE_ID=

# The base URL of your site, used for generating canonical URLs and sitemaps.
NEXT_PUBLIC_SITE_URL=https://simonesiega.com

# Optional server-only fallback for canonical URLs when NEXT_PUBLIC_SITE_URL is not set.
SITE_URL=https://simonesiega.com

# Optional: off | report-only | enforce. Defaults to enforce in production when unset.
# CSP_MODE=enforce
# Optional CSP reporting endpoint and additional connect-src origins.
CSP_REPORT_URI=
CSP_CONNECT_SRC_EXTRA=
